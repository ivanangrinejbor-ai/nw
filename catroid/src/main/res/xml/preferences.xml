        <CheckBoxPreference
            android:defaultValue="true"
            android:key="pref_grouping_threed"
            android:summary="@string/preference_description_grouping_threed"
            android:title="@string/preference_title_grouping_threed" />

    </PreferenceScreen>

    <CheckBoxPreference
        android:defaultValue="@string/SNACKBAR_HINTS_ENABLED"
        android:key="setting_enable_hints"
        android:summary="@string/preference_description_hints"
        android:title="@string/preference_title_enable_hints" />

    <CheckBoxPreference
        android:defaultValue="@string/DEBUG_MODE"
        android:key="setting_test_bricks"
        android:summary="@string/preference_description_test_bricks"
        android:title="@string/preference_title_enable_test_bricks" />

    <CheckBoxPreference
        android:key="pref_1_april_enabled"
        android:title="1 APRIL"
        android:summary=":]"
        android:defaultValue="true" />

    <CheckBoxPreference
        android:key="pref_code_analysis_enabled"
        android:title="Анализ кода в реальном времени"
        android:summary="Автоматически проверять скрипты на наличие потенциальных проблем и ошибок."
        android:defaultValue="true" />

    <CheckBoxPreference
        android:key="setting_ai_assistant"
        android:title="@string/ai_assist"
        android:summary="@string/preference_description_ai_assistant"
        android:defaultValue="false" />

    <PreferenceCategory android:title="@string/github_integration">

        <Preference
            android:key="setting_github_login"
            android:title="@string/github_account"
            android:summary="@string/github_not_logged_in" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/additions">

        <PreferenceScreen
            android:key="setting_plugins_screen"
            android:title="@string/plugins"
            android:summary="@string/plugins_desc"
            android:icon="@android:drawable/ic_menu_add" />

        <PreferenceScreen
            android:key="setting_ide_screen"
            android:title="IDE"
            android:summary="@string/ide_desc"
            android:icon="@android:drawable/ic_menu_add"
            app:isPreferenceVisible="false" />

    </PreferenceCategory>

    <!-- https://www.meme-arsenal.com/memes/d3d151ea76e2feed9edb2d82e14133ff.jpg -->

    <CheckBoxPreference
        android:defaultValue="true"
        android:key="setting_enable_crash_reports"
        android:summary="@string/preference_description_crash_reports"
        android:title="@string/preference_title_enable_crash_reports" />


    <PreferenceCategory android:title="@string/recovery">
        <Preference
            android:key="setting_recover_projects"
            android:title="@string/recovery_btn"
            android:summary="@string/recovery_desc" />
    </PreferenceCategory>

</PreferenceScreen>
