    <CheckBoxPreference
        android:defaultValue="false"
        android:key="setting_parrot_jumping_sumo_bricks"
        android:summary="@string/preference_description_jumpingsumo_bricks"
        android:title="@string/preference_title_enable_jumpingsumo_bricks" />

     <CheckBoxPreference
         android:defaultValue="false"
         android:key="setting_arduino_bricks"
         android:summary="@string/preference_description_arduino_bricks"
         android:title="@string/preference_title_enable_arduino_bricks" />

    <CheckBoxPreference
        android:defaultValue="false"
        android:key="setting_nfc_bricks"
        android:summary="@string/preference_description_nfc_bricks"
        android:title="@string/preference_title_enable_nfc_bricks" />

    <PreferenceScreen
        android:key="settings_raspberry_screen"
        android:summary="@string/preference_description_raspi_bricks"
        android:title="@string/preference_title_enable_raspi_bricks" />

    <Preference
        android:key="setting_enable_phiro_bricks_preference"
        android:summary="@string/preference_description_phiro_bricks"
        android:title="@string/preference_title_enable_phiro_bricks" />

    <CheckBoxPreference
        android:defaultValue="@string/FEATURE_PHIRO_PREFERENCES_ENABLED"
        android:key="setting_enable_phiro_bricks_checkbox_preference"
        android:summary="@string/preference_description_phiro_bricks"
        android:title="@string/preference_title_enable_phiro_bricks" />

    <CheckBoxPreference
        android:defaultValue="false"
        android:key="setting_cast_globally_enabled"
        android:summary="@string/preference_description_cast_feature_globally_enabled"
        android:title="@string/preference_title_cast_feature_globally_enabled" />

    <PreferenceScreen
        android:key="setting_accessibility_screen"
        android:summary="@string/preference_description_accessibility"
        android:title="@string/preference_title_accessibility" />

    <PreferenceScreen
        android:key="setting_block_grouping_screen"
        android:summary="@string/preference_description_block_grouping"
        android:title="@string/preference_title_block_grouping">

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="pref_grouping_event"
            android:summary="@string/preference_description_grouping_event"
            android:title="@string/preference_title_grouping_event" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="pref_grouping_control"
            android:summary="@string/preference_description_grouping_control"
            android:title="@string/preference_title_grouping_control" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="pref_grouping_motion"
            android:summary="@string/preference_description_grouping_motion"
            android:title="@string/preference_title_grouping_motion" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="pref_grouping_sound"
            android:summary="@string/preference_description_grouping_sound"
            android:title="@string/preference_title_grouping_sound" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="pref_grouping_looks"
            android:summary="@string/preference_description_grouping_looks"
            android:title="@string/preference_title_grouping_looks" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="pref_grouping_data"
            android:summary="@string/preference_description_grouping_data"
