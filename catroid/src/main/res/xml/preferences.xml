            android:summary="@string/free_window_mode_project_sum"
            android:defaultValue="false" />

        <CheckBoxPreference
            android:key="pref_workspace_stage"
            android:title="@string/free_window_mode_stage"
            android:summary="@string/free_window_mode_stage_sum"
            android:defaultValue="false" />

    </PreferenceScreen>

    <CheckBoxPreference
        android:defaultValue="@string/FEATURE_EMBROIDERY_PREFERENCES_ENABLED"
