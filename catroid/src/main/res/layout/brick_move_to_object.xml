<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_move_to_layout"
        style="@style/BrickContainer.Look.Medium">

        <include layout="@layout/icon_brick_category_look" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pathfinder_move_to" />

        <Spinner
            android:id="@+id/brick_move_to_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_newLine="true" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pathfinder_avoid"
            app:layout_newLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_newLine="true">

            <TextView
                android:id="@+id/brick_move_to_avoid_edit"
                style="@style/BrickEditText"
                android:layout_width="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/brick_move_to_avoid_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..." />
        </LinearLayout>

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pathfinder_speed"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_move_to_speed_edit"
            style="@style/BrickEditText" />
    </org.catrobat.catroid.ui.BrickLayout>

</LinearLayout>
