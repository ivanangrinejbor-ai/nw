<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/app_background"
    android:baselineAligned="false">

    <RelativeLayout
        android:layout_width="400dp"
        android:layout_height="match_parent"
        android:background="@color/app_background">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:id="@+id/currentProjectLayout"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="@color/button_background">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/projectImageView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#33000000" />

                        <ImageView
                            android:id="@+id/editProject"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_centerInParent="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_edit_circle"
                            app:tint="@color/solid_white"/>

                        <ImageView
                            android:id="@+id/playProject"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:layout_margin="16dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_play_circle" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <Space android:layout_width="match_parent" android:layout_height="24dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnWeb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/button_background"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/main_menu_web"
                        android:textColor="@color/landing_page_icons"
                        android:textSize="16sp"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        app:drawableStartCompat="@drawable/code_24px"
                        app:drawableEndCompat="@drawable/ic_arrow_forward_vector"
                        android:drawablePadding="16dp" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnCommunity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/button_background"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/main_menu_community"
                        android:textColor="@color/landing_page_icons"
                        android:textSize="16sp"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        app:drawableStartCompat="@drawable/language_24px"
                        app:drawableEndCompat="@drawable/ic_arrow_forward_vector"
                        android:drawablePadding="16dp" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnNewProjectFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="24dp"
            android:contentDescription="@string/main_menu_new"
            android:src="@drawable/ic_plus"
            app:tint="@color/solid_white"
            app:backgroundTint="@color/button_background"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.NeoCatroid.FAB"
            app:fabCustomSize="65dp"
            app:elevation="8dp" />

    </RelativeLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="?attr/dividerHorizontal" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/pc_project_list_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1" />

</LinearLayout>
