<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2D2D30"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_open_files"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?selectableItemBackground"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="#FFFFFF" />

                <Button
                    android:id="@+id/btn_ai_assistant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#6200EE"
                    android:text="Чат с ИИ"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_check_syntax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#555555"
                    android:text="Проверить (Локально)"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_build_cloud"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#4CAF50"
                    android:text="Build (Облако)"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_create_pr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#03A9F4"
                    android:text="Отправить PR"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tabs_recycler"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="#1E1E1E"
            android:orientation="horizontal" />

        <io.github.rosemoe.sora.widget.CodeEditor
            android:id="@+id/editor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/bottom_panel"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:orientation="vertical"
            android:background="#252526"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#333333"
                android:padding="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ассистент ИИ / Консоль"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>
                <ImageButton
                    android:id="@+id/btn_close_bottom_panel"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?selectableItemBackground"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#FFFFFF"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ai_chat_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="#1E1E1E">
                <EditText
                    android:id="@+id/ai_input_field"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Попроси добавить фичу..."
                    android:textColorHint="#888888"
                    android:textColor="#FFFFFF"
                    android:background="@android:color/transparent"
                    android:padding="8dp"/>
                <ImageButton
                    android:id="@+id/btn_send_ai"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?selectableItemBackground"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#4CAF50"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#252526"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Файлы проекта"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/file_tree_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
