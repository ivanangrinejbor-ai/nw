<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/project_options_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:divider="@drawable/divider"
           android:orientation="vertical"
           android:showDividers="end">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/project_options_name_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/project_name_label"
                android:paddingEnd="@dimen/dialog_content_area_padding"
                android:paddingStart="@dimen/dialog_content_area_padding"
                android:paddingTop="@dimen/dialog_content_area_padding_top"
                app:errorEnabled="true"
                app:hintEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/project_options_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:selectAllOnFocus="true" />

            </com.google.android.material.textfield.TextInputLayout>

       </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/project_options_description_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/project_options_description"
                android:paddingEnd="@dimen/dialog_content_area_padding"
                android:paddingStart="@dimen/dialog_content_area_padding"
                android:paddingTop="@dimen/dialog_content_area_padding_top"
                app:errorEnabled="true"
                app:hintEnabled="true"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/landscape_2_24px"
                app:endIconContentDescription="@string/insert_image">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/project_options_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:selectAllOnFocus="true" />

            </com.google.android.material.textfield.TextInputLayout>

       </LinearLayout>

       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:divider="@drawable/divider"
           android:orientation="vertical"
           android:showDividers="end">

           <com.google.android.material.textfield.TextInputLayout
               android:id="@+id/project_options_notes_and_credits_layout"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:hint="@string/project_options_notes_and_credits"
               android:paddingEnd="@dimen/dialog_content_area_padding"
               android:paddingStart="@dimen/dialog_content_area_padding"
               android:paddingTop="@dimen/dialog_content_area_padding_top"
               app:errorEnabled="true"
               app:hintEnabled="true">

               <com.google.android.material.textfield.TextInputEditText
                   android:id="@+id/project_options_notes_and_credits"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:selectAllOnFocus="true" />

           </com.google.android.material.textfield.TextInputLayout>

       </LinearLayout>

       <LinearLayout
           android:id="@+id/tags"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:divider="@drawable/divider"
           android:orientation="vertical"
           android:showDividers="end">

           <TextView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:paddingStart="@dimen/dialog_content_area_padding"
               android:paddingEnd="@dimen/dialog_content_area_padding"
               android:paddingTop="@dimen/dialog_content_area_padding_top"
               android:hint="@string/project_options_tags" />

           <com.google.android.material.chip.ChipGroup
               android:id="@+id/chip_group_tags"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:paddingBottom="@dimen/dialog_content_area_padding_input"
               android:paddingStart="@dimen/dialog_content_area_padding"
               android:paddingEnd="@dimen/dialog_content_area_padding"/>
       </LinearLayout>

       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:divider="@drawable/divider"
           android:orientation="vertical"
           android:showDividers="end">

           <com.google.android.material.switchmaterial.SwitchMaterial
               android:id="@+id/project_options_aspect_ratio"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:checked="true"
               android:paddingBottom="@dimen/material_design_spacing_x_large"
               android:paddingEnd="@dimen/material_design_spacing_x_large"
               android:paddingStart="@dimen/material_design_spacing_x_large"
               android:paddingTop="@dimen/material_design_spacing_x_large"
               android:textColor="#B2FFFFFF"
               android:text="@string/project_options_aspect_ratio"/>

       </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/project_options_custom_resolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="false"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:textColor="#B2FFFFFF"
                android:text="@string/project_options_custom_resolution"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/project_options_physics_width_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/project_physics_width"
                android:paddingEnd="@dimen/dialog_content_area_padding"
                android:paddingStart="@dimen/dialog_content_area_padding"
                android:paddingTop="@dimen/dialog_content_area_padding_top"
                app:errorEnabled="true"
                app:hintEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/project_options_physics_width"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:selectAllOnFocus="true" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/project_options_physics_height_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/project_physics_height"
                android:paddingEnd="@dimen/dialog_content_area_padding"
                android:paddingStart="@dimen/dialog_content_area_padding"
                android:paddingTop="@dimen/dialog_content_area_padding_top"
                app:errorEnabled="true"
                app:hintEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/project_options_physics_height"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:selectAllOnFocus="true" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:divider="@drawable/divider"
           android:orientation="vertical"
           android:visibility="gone"
           android:showDividers="end">

           <TextView
               android:id="@+id/project_options_upload"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:paddingBottom="@dimen/material_design_spacing_x_large"
               android:paddingEnd="@dimen/material_design_spacing_x_large"
               android:paddingStart="@dimen/material_design_spacing_x_large"
               android:paddingTop="@dimen/material_design_spacing_x_large"
               android:background="@drawable/button_background_selector_dark"
               android:text="Экспорт для сервера" />

       </LinearLayout>

       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:divider="@drawable/divider"
           android:orientation="vertical"
           android:showDividers="end">

           <TextView
               android:id="@+id/project_options_save_external"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:paddingBottom="@dimen/material_design_spacing_x_large"
               android:paddingEnd="@dimen/material_design_spacing_x_large"
               android:paddingStart="@dimen/material_design_spacing_x_large"
               android:paddingTop="@dimen/material_design_spacing_x_large"
               android:background="@drawable/button_background_selector_dark"
               android:text="@string/save_to_external_storage_button" />

       </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <TextView
                android:id="@+id/project_options_save_apk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:background="@drawable/button_background_selector_dark"
                android:text="@string/save_apk_button" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <TextView
                android:id="@+id/project_options_clear_vars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:background="@drawable/button_background_selector_dark"
                android:text="@string/clear_vars_button" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <TextView
                android:id="@+id/project_options_change_icon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:background="@drawable/button_background_selector_dark"
                android:text="@string/change_icon_button" />

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <TextView
                android:id="@+id/project_options_change_orientation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:background="@drawable/button_background_selector_dark"
                android:text="@string/change_orientation_button" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <TextView
                android:id="@+id/project_options_rebuild_cache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:background="@drawable/button_background_selector_dark"
                android:text="@string/rebuild_cache_button" />

        </LinearLayout>

       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:divider="@drawable/divider"
           android:orientation="vertical"
           android:showDividers="end">

           <TextView
               android:id="@+id/project_options_more_details"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:paddingBottom="@dimen/material_design_spacing_x_large"
               android:paddingEnd="@dimen/material_design_spacing_x_large"
               android:paddingStart="@dimen/material_design_spacing_x_large"
               android:paddingTop="@dimen/material_design_spacing_x_large"
               android:background="@drawable/button_background_selector_dark"
               android:text="@string/project_options_more_details" />

       </LinearLayout>

        <!--<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end">

            <TextView
                android:id="@+id/project_options_mishk_frede"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:background="@drawable/button_background_selector_dark"
                android:text="@string/ogurec" />

        </LinearLayout>-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:showDividers="end"
            android:visibility="gone">

            <TextView
                android:id="@+id/project_options_bake"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:background="@drawable/button_background_selector_dark"
                android:text="Запечь проект (Bake)" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/divider"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:showDividers="middle|end">

            <TextView
                style="@style/TextAppearance.AppCompat.Subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingBottom="8dp"
                android:text="@string/github_integration" />

            <TextView
                android:id="@+id/git_connect_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_background_selector_dark"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:text="@string/git_connect" />

            <TextView
                android:id="@+id/git_publish_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_background_selector_dark"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:text="@string/git_publish_changes"
                android:visibility="gone" />

            <TextView
                android:id="@+id/git_update_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_background_selector_dark"
                android:paddingStart="@dimen/material_design_spacing_x_large"
                android:paddingTop="@dimen/material_design_spacing_x_large"
                android:paddingEnd="@dimen/material_design_spacing_x_large"
                android:paddingBottom="@dimen/material_design_spacing_x_large"
                android:text="@string/git_update_project"
                android:visibility="gone" />

        </LinearLayout>

        <Button
            android:id="@+id/project_options_delete"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/material_design_spacing_x_large"
            android:layout_marginTop="@dimen/material_design_spacing_x_large"
            android:backgroundTint="@color/red"
            android:text="@string/project_options_delete_project"
            android:textAllCaps="true" />

     </LinearLayout>
 </ScrollView>
