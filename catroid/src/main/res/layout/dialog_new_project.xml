<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/app_background"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:animateLayoutChanges="true">

            <include layout="@layout/toolbar" android:id="@+id/toolbar" />

            <LinearLayout
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:animateLayoutChanges="true">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input"
                    style="@style/NeoCatroid.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:hintEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/solid_white"
                        android:textSize="18sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/standard_settings_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ориентация проекта"
                        android:textColor="@color/accent"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/orientation_toggle_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:checkedButton="@id/btn_portrait">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_portrait"
                            style="@style/Widget.NeoCatroid.ToggleButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="54dp"
                            app:icon="@drawable/ic_smartphone_dialog_orientation_portrait"
                            android:text="@string/new_project_dialog_portrait" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_landscape"
                            style="@style/Widget.NeoCatroid.ToggleButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="54dp"
                            app:icon="@drawable/ic_smartphone_dialog_orientation_landscape"
                            android:text="@string/new_project_dialog_landscape" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/example_project_switch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/solid_white"
                        android:text="@string/new_project_dialog_example_project"
                        app:thumbTint="@color/accent" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/button_background" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/git_clone_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Клонировать репозиторий Git"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    app:thumbTint="@color/accent" />

                <LinearLayout
                    android:id="@+id/git_input_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/NeoCatroid.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Remote URL">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/git_url_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/NeoCatroid.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Access Token (optional)">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/git_token_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:inputType="textPassword"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/git_progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:visibility="gone"
                    android:indeterminateTint="@color/accent" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>