                      <value>def vigenere_encrypt(user_text, user_key):
    encrypted_text = []
    key_length = len(user_key)
    key_index = 0

    # Определяем диапазоны для латиницы и кириллицы
    latin_lower_start, latin_lower_end = ord(&apos;a&apos;), ord(&apos;z&apos;)
    latin_upper_start, latin_upper_end = ord(&apos;A&apos;), ord(&apos;Z&apos;)
    cyrillic_lower_start, cyrillic_lower_end = ord(&apos;а&apos;), ord(&apos;я&apos;)
    cyrillic_upper_start, cyrillic_upper_end = ord(&apos;А&apos;), ord(&apos;Я&apos;)

    for char in user_text:
        if char.isalpha():
            # Обработка латинских букв
            if &apos;a&apos; &lt;= char &lt;= &apos;z&apos; or &apos;A&apos; &lt;= char &lt;= &apos;Z&apos;:
                shift = ord(user_key[key_index % key_length].lower()) - ord(&apos;a&apos;)
                if char.islower():
                    encrypted_char = chr((ord(char) - ord(&apos;a&apos;) + shift) % 26 + ord(&apos;a&apos;))
                else:
                    encrypted_char = chr((ord(char) - ord(&apos;A&apos;) + shift) % 26 + ord(&apos;A&apos;))
                encrypted_text.append(encrypted_char)
                key_index += 1

            # Обработка кириллических букв
            elif &apos;а&apos; &lt;= char &lt;= &apos;я&apos;:
                shift = (ord(user_key[key_index % key_length].lower()) - ord(&apos;а&apos;)) if &apos;а&apos; &lt;= user_key[key_index % key_length].lower() &lt;= &apos;я&apos; else 0
                encrypted_char = chr((ord(char) - ord(&apos;а&apos;) + shift) % 32 + ord(&apos;а&apos;))
                encrypted_text.append(encrypted_char)
                key_index += 1
            elif &apos;А&apos; &lt;= char &lt;= &apos;Я&apos;:
                shift = (ord(user_key[key_index % key_length].upper()) - ord(&apos;А&apos;)) if &apos;А&apos; &lt;= user_key[key_index % key_length].upper() &lt;= &apos;Я&apos; else 0
                encrypted_char = chr((ord(char) - ord(&apos;А&apos;) + shift) % 32 + ord(&apos;А&apos;))
                encrypted_text.append(encrypted_char)
                key_index += 1
            else:
                # Если символ не входит в известные диапазоны, оставляем его без изменений
                encrypted_text.append(char)
        elif char.isdigit():
            # Шифруем цифры
            encrypted_char = str((int(char) + int(user_key[key_index % key_length])) % 10)
            encrypted_text.append(encrypted_char)
            key_index += 1
        elif char.isspace():
            # Обработка пробелов
            encrypted_text.append(&apos;#&apos;)
            key_index += 1
        else:
            # Другие символы оставляем без изменений
            encrypted_text.append(char)

    return &apos;&apos;.join(encrypted_text)

