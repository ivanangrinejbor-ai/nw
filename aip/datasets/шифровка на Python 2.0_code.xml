                      <value>def vigenere_decrypt(encrypted_text, user_key):
    decrypted_text = []
    key_length = len(user_key)
    key_index = 0

    # Определяем диапазоны для латиницы и кириллицы
    latin_lower_start, latin_lower_end = ord(&apos;a&apos;), ord(&apos;z&apos;)
    latin_upper_start, latin_upper_end = ord(&apos;A&apos;), ord(&apos;Z&apos;)
    cyrillic_lower_start, cyrillic_lower_end = ord(&apos;а&apos;), ord(&apos;я&apos;)
    cyrillic_upper_start, cyrillic_upper_end = ord(&apos;А&apos;), ord(&apos;Я&apos;)

    for char in encrypted_text:
        if char.isalpha():
            # Обработка латинских букв
            if &apos;a&apos; &lt;= char &lt;= &apos;z&apos; or &apos;A&apos; &lt;= char &lt;= &apos;Z&apos;:
                shift = ord(user_key[key_index % key_length].lower()) - ord(&apos;a&apos;)
                # Расшифровка
                if char.islower():
                    decrypted_char = chr((ord(char) - ord(&apos;a&apos;) - shift) % 26 + ord(&apos;a&apos;))
                else:
                    decrypted_char = chr((ord(char) - ord(&apos;A&apos;) - shift) % 26 + ord(&apos;A&apos;))
                decrypted_text.append(decrypted_char)
                key_index += 1

            # Обработка кириллических букв
            elif &apos;а&apos; &lt;= char &lt;= &apos;я&apos;:
                # Вычисляем сдвиг для кириллицы
                key_char = user_key[key_index % key_length]
                if &apos;а&apos; &lt;= key_char &lt;= &apos;я&apos;:
                    shift = ord(key_char.lower()) - ord(&apos;а&apos;)
                elif &apos;А&apos; &lt;= key_char &lt;= &apos;Я&apos;:
                    shift = ord(key_char.upper()) - ord(&apos;А&apos;)
                else:
                    shift = 0
                decrypted_char = chr((ord(char) - ord(&apos;а&apos;) - shift) % 32 + ord(&apos;а&apos;))
                decrypted_text.append(decrypted_char)
                key_index += 1
            elif &apos;А&apos; &lt;= char &lt;= &apos;Я&apos;:
                key_char = user_key[key_index % key_length]
                if &apos;А&apos; &lt;= key_char &lt;= &apos;Я&apos;:
                    shift = ord(key_char.upper()) - ord(&apos;А&apos;)
                elif &apos;а&apos; &lt;= key_char &lt;= &apos;я&apos;:
                    shift = ord(key_char.lower()) - ord(&apos;а&apos;)
                else:
                    shift = 0
                decrypted_char = chr((ord(char) - ord(&apos;А&apos;) - shift) % 32 + ord(&apos;А&apos;))
                decrypted_text.append(decrypted_char)
                key_index += 1
            else:
                # Если символ не входит в диапазоны, оставляем как есть
                decrypted_text.append(char)
        elif char.isdigit():
            # Расшифровка цифр
            shift = int(user_key[key_index % key_length]) if user_key[key_index % key_length].isdigit() else 0
            decrypted_char = str((int(char) - shift) % 10)
            decrypted_text.append(decrypted_char)
            key_index += 1
        elif char == &apos;#&apos;:
            # Обратное преобразование для пробелов
            decrypted_text.append(&apos; &apos;)
            key_index += 1
        else:
            # Другие символы остаются без изменений
            decrypted_text.append(char)

    return &apos;&apos;.join(decrypted_text)

