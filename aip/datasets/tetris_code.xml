&lt;body&gt;

&lt;h1&gt;Tetris&lt;/h1&gt;

&lt;div&gt;
Score:
&lt;span id=&quot;score&quot;&gt;0&lt;/span&gt;
&lt;/div&gt;

&lt;div id=&quot;game&quot;&gt;&lt;/div&gt;

&lt;div class=&quot;controls&quot;&gt;

&lt;button onclick=&quot;move(-1,0)&quot;&gt;
◀
&lt;/button&gt;

&lt;button onclick=&quot;move(1,0)&quot;&gt;
▶
&lt;/button&gt;

&lt;button onclick=&quot;move(0,1)&quot;&gt;
▼
&lt;/button&gt;

&lt;button onclick=&quot;rotatePiece()&quot;&gt;
⟳
&lt;/button&gt;

&lt;/div&gt;

&lt;script&gt;

/* BOARD */

const COLS = 10;
const ROWS = 20;

const game =
  document.getElementById(&quot;game&quot;);

/* CREATE CELLS */

const cells = [];

for(let i=0;i&lt;ROWS*COLS;i++){

  const div =
    document.createElement(&quot;div&quot;);

  div.className=&quot;cell&quot;;

  game.appendChild(div);

  cells.push(div);
}

/* SHAPES */

const SHAPES = {

I:[
 [1,1,1,1]
],

O:[
 [1,1],
 [1,1]
],

T:[
 [0,1,0],
 [1,1,1]
],

L:[
 [0,0,1],
 [1,1,1]
]

};

const COLORS = {

I:&quot;#00ffff&quot;,
O:&quot;#ffff00&quot;,
T:&quot;#aa00ff&quot;,
L:&quot;#ff8800&quot;

};

/* GAME DATA */

let board =
  Array.from(
    {length:ROWS},
    ()=&gt;Array(COLS).fill(0)
  );

let piece =
  randomPiece();

let score = 0;

/* RANDOM */

function randomPiece(){

  const keys =
    Object.keys(SHAPES);

  const type =
    keys[Math.random()*keys.length|0];

  return {

    type:type,

    shape:SHAPES[type],

    x:3,

    y:0

  };

}

/* DRAW */

function draw(){

  let temp =
    board.map(r=&gt;[...r]);

  piece.shape.forEach((row,y)=&gt;{

    row.forEach((v,x)=&gt;{

      if(v){

        let px =
          piece.x+x;

        let py =
          piece.y+y;

        if(
          py&gt;=0 &amp;&amp;
          py&lt;ROWS &amp;&amp;
          px&gt;=0 &amp;&amp;
          px&lt;COLS
        ){

          temp[py][px] =
            piece.type;

        }

      }

    });

  });

  let i=0;

  temp.forEach(row=&gt;{

    row.forEach(cell=&gt;{

      cells[i].style.background =
        cell
        ? COLORS[cell]
        : &quot;#111&quot;;

      i++;

    });

  });

  document.getElementById(&quot;score&quot;)
  .innerText=score;
}

/* COLLISION */

function collide(p){

  for(let y=0;y&lt;p.shape.length;y++){

    for(let x=0;x&lt;p.shape[y].length;x++){

      if(!p.shape[y][x])
        continue;

      let px =
        p.x+x;

      let py =
        p.y+y;

      if(
        px&lt;0 ||
        px&gt;=COLS ||
        py&gt;=ROWS
      ){
        return true;
      }

      if(
        py&gt;=0 &amp;&amp;
        board[py][px]
      ){
        return true;
      }

    }

  }

  return false;
}

/* MERGE */

function merge(){

  piece.shape.forEach((row,y)=&gt;{

    row.forEach((v,x)=&gt;{

      if(v){

        board[piece.y+y]
             [piece.x+x]
             = piece.type;

      }

    });

  });

}

/* CLEAR */

function clearLines(){

  let lines = 0;

  board =
    board.filter(row=&gt;{

      if(row.every(v=&gt;v)){

        lines++;

        return false;
      }

      return true;

    });

  while(board.length&lt;ROWS){

    board.unshift(
      Array(COLS).fill(0)
    );

  }

  score += lines*100;
}

/* MOVE */

function move(dx,dy){

  let p = {

    ...piece,

    x:piece.x+dx,

    y:piece.y+dy

  };

  if(!collide(p)){

    piece = p;

  }else if(dy===1){

    merge();

    clearLines();

    piece =
      randomPiece();

    if(collide(piece)){

      alert(&quot;Game Over&quot;);

      board =
        Array.from(
          {length:ROWS},
          ()=&gt;Array(COLS).fill(0)
        );

      score = 0;
    }

  }

  draw();
}

/* ROTATE */

function rotatePiece(){

  let rotated =
    piece.shape[0]
    .map((_,i)=&gt;
      piece.shape
      .map(r=&gt;r[i])
      .reverse()
    );

  let p = {

    ...piece,

    shape:rotated

  };

  if(!collide(p)){

    piece = p;

  }

  draw();
}

/* KEYBOARD */

document.addEventListener(
  &quot;keydown&quot;,
  e=&gt;{

    if(e.key===&quot;ArrowLeft&quot;)
      move(-1,0);

    if(e.key===&quot;ArrowRight&quot;)
      move(1,0);

    if(e.key===&quot;ArrowDown&quot;)
      move(0,1);

    if(e.key===&quot;ArrowUp&quot;)
      rotatePiece();

  }
);

/* GAME LOOP */

function loop(){

  move(0,1);

}

setInterval(loop,500);

/* START */

draw();

&lt;/script&gt;

