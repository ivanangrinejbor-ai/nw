                      <value>&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;ru&quot;&gt;
&lt;head&gt;
&lt;meta charset=&quot;UTF-8&quot;&gt;
&lt;meta name=&quot;viewport&quot;
content=&quot;width=device-width,
initial-scale=1,
maximum-scale=1,
user-scalable=no&quot;&gt;

&lt;title&gt;Tetris Fixed&lt;/title&gt;

&lt;style&gt;

html,body{
  margin:0;
  padding:0;
  overflow:hidden;

  background:#111;
  color:white;

  font-family:Arial;

  display:flex;
