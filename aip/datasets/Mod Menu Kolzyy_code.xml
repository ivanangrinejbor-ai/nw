&lt;body&gt;
    &lt;div class=&quot;menu-container&quot;&gt;
        &lt;div class=&quot;top-bar&quot;&gt;
            &lt;h3&gt;KOLZYY MOD MENU TEMPLATE&lt;/h3&gt;
            &lt;p&gt;by @KolzyyF&lt;/p&gt;
        &lt;/div&gt;

        &lt;div class=&quot;settings-section&quot;&gt;
            &lt;div class=&quot;section-title&quot;&gt;⚙️ НАСТРОЙКИ ЧИТА&lt;/div&gt;
            
            &lt;div class=&quot;checkbox-item&quot; onclick=&quot;document.getElementById(&apos;chk_aimbot&apos;).click()&quot;&gt;
                &lt;input type=&quot;checkbox&quot; id=&quot;chk_aimbot&quot;&gt;
                &lt;span class=&quot;custom-checkbox&quot;&gt;&lt;/span&gt;
                &lt;label&gt;🔫 AimBot&lt;/label&gt;
            &lt;/div&gt;
            
            &lt;div class=&quot;checkbox-item&quot; onclick=&quot;document.getElementById(&apos;chk_esp&apos;).click()&quot;&gt;
                &lt;input type=&quot;checkbox&quot; id=&quot;chk_esp&quot;&gt;
                &lt;span class=&quot;custom-checkbox&quot;&gt;&lt;/span&gt;
                &lt;label&gt;👁️ ESP&lt;/label&gt;
            &lt;/div&gt;
            
            &lt;div class=&quot;checkbox-item&quot; onclick=&quot;document.getElementById(&apos;chk_speed&apos;).click()&quot;&gt;
                &lt;input type=&quot;checkbox&quot; id=&quot;chk_speed&quot;&gt;
                &lt;span class=&quot;custom-checkbox&quot;&gt;&lt;/span&gt;
                &lt;label&gt;⚡ SpeedHack&lt;/label&gt;
            &lt;/div&gt;
            
            &lt;div class=&quot;checkbox-item&quot; onclick=&quot;document.getElementById(&apos;chk_skin&apos;).click()&quot;&gt;
                &lt;input type=&quot;checkbox&quot; id=&quot;chk_skin&quot;&gt;
                &lt;span class=&quot;custom-checkbox&quot;&gt;&lt;/span&gt;
                &lt;label&gt;🎨 Skin Changer&lt;/label&gt;
            &lt;/div&gt;
            
            &lt;div class=&quot;checkbox-item&quot; onclick=&quot;document.getElementById(&apos;chk_ammo&apos;).click()&quot;&gt;
                &lt;input type=&quot;checkbox&quot; id=&quot;chk_ammo&quot;&gt;
                &lt;span class=&quot;custom-checkbox&quot;&gt;&lt;/span&gt;
                &lt;label&gt;📦 Infinite Ammo&lt;/label&gt;
            &lt;/div&gt;
        &lt;/div&gt;

        &lt;div class=&quot;buttons-section&quot;&gt;
            &lt;button class=&quot;glow-on-hover&quot; onclick=&quot;applySettings()&quot;&gt;✅ ПРИМЕНИТЬ&lt;/button&gt;
            &lt;button class=&quot;btnpro&quot; onclick=&quot;sendCommand(&apos;telegram&apos;)&quot;&gt;📱 TELEGRAM&lt;/button&gt;
            &lt;button class=&quot;btnpro exit-btn&quot; onclick=&quot;sendCommand(&apos;exit&apos;)&quot;&gt;❌ ВЫХОД&lt;/button&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;script&gt;
        // Функция отправки (как в вашем примере)
        function sendCommand(text) {
            if (window.Android &amp;&amp; Android.postMessage) {
                Android.postMessage(text);
            }
        }

        // ПРИМЕНИТЬ - собираем ВСЕ включённые галочки
        function applySettings() {
            const aimbot = document.getElementById(&apos;chk_aimbot&apos;).checked;
            const esp = document.getElementById(&apos;chk_esp&apos;).checked;
            const speedhack = document.getElementById(&apos;chk_speed&apos;).checked;
            const skinchanger = document.getElementById(&apos;chk_skin&apos;).checked;
            const infiniteAmmo = document.getElementById(&apos;chk_ammo&apos;).checked;
            
            // Собираем ВСЕ включённые параметры в массив
            const enabled = [];
            
            if (aimbot) enabled.push(&apos;aimbot&apos;);
            if (esp) enabled.push(&apos;esp&apos;);
            if (speedhack) enabled.push(&apos;speed&apos;);
            if (skinchanger) enabled.push(&apos;skin&apos;);
            if (infiniteAmmo) enabled.push(&apos;ammo&apos;);
            
            // Если ничего не выбрано - не отправляем
            if (enabled.length === 0) {
                return;
            }
            
            // Формируем команду: apply_aimbot+esp+speed+skin+ammo
            const command = &apos;apply_&apos; + enabled.join(&apos;+&apos;);
            
            // Отправляем
            sendCommand(command);
        }
    &lt;/script&gt;
