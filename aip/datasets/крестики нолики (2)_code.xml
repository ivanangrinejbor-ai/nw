&lt;title&gt;Крестики-Нолики AI&lt;/title&gt;

&lt;style&gt;
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    overflow:hidden;
    height:100vh;
    background:
        radial-gradient(circle at top,#16213e,#0f172a 60%);
    color:white;
}

/* ФОН */
.bg{
    position:fixed;
    inset:0;
    z-index:-1;
    overflow:hidden;
}

.bg span{
    position:absolute;
    bottom:-100px;
    border-radius:50%;
    background:rgba(255,255,255,0.08);
    animation:float linear infinite;
}

@keyframes float{
    from{
        transform:translateY(0) rotate(0deg);
        opacity:0;
    }
    10%{
        opacity:1;
    }
    to{
        transform:translateY(-120vh) rotate(720deg);
        opacity:0;
    }
}

/* ЭКРАНЫ */
.screen{
    position:absolute;
    inset:0;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
}

.hidden{
    display:none;
}

/* НАЗВАНИЕ */
.title{
    font-size:64px;
    margin-bottom:30px;
    text-align:center;
    line-height:1.1;

    text-shadow:
        0 0 15px cyan,
        0 0 35px cyan;
}

.menu-box{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:20px;
}

.btn{
    width:260px;
    padding:18px;
    border:none;
    border-radius:18px;
    font-size:24px;
    font-weight:bold;
    color:white;
    cursor:pointer;
    transition:.25s;
    background:rgba(255,255,255,0.1);
    border:1px solid rgba(255,255,255,0.2);
    backdrop-filter:blur(10px);
}

.btn:hover{
    transform:scale(1.08);
    box-shadow:
        0 0 20px cyan,
        0 0 40px cyan;
}

.choice-title{
    margin-top:10px;
    font-size:22px;
}

.choice-box{
    display:flex;
    gap:25px;
}

.choice{
    width:90px;
    height:90px;
    border-radius:20px;
    border:2px solid rgba(255,255,255,0.2);
    background:rgba(255,255,255,0.08);
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:50px;
    cursor:pointer;
    transition:.25s;
}

.choice:hover{
    transform:scale(1.1);
}

.choice.selected{
    box-shadow:
        0 0 20px cyan,
        0 0 40px cyan;
}

/* ИГРА */
.status{
    margin-bottom:20px;
    font-size:30px;
    text-shadow:0 0 10px cyan;
}

.board{
    display:grid;
    grid-template-columns:repeat(3,120px);
    gap:15px;
}

.cell{
    width:120px;
    height:120px;
    border-radius:22px;
    background:rgba(255,255,255,0.08);
    border:2px solid rgba(255,255,255,0.15);
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:65px;
    cursor:pointer;
    transition:.2s;
    backdrop-filter:blur(6px);
}

.cell:hover{
    transform:scale(1.05);
}

.x{
    color:#00e5ff;
    text-shadow:0 0 15px #00e5ff;
}

.o{
    color:#ff4da6;
    text-shadow:0 0 15px #ff4da6;
}

.controls{
    margin-top:25px;
    display:flex;
    gap:15px;
}

.small-btn{
    padding:14px 22px;
    border:none;
    border-radius:14px;
    cursor:pointer;
    font-size:18px;
    color:white;
    background:rgba(255,255,255,0.1);
    transition:.25s;
}

.small-btn:hover{
    transform:scale(1.05);
    box-shadow:0 0 15px cyan;
}

@media(max-width:600px){

    .title{
        font-size:42px;
    }

    .board{
        grid-template-columns:repeat(3,90px);
    }

    .cell{
        width:90px;
        height:90px;
        font-size:48px;
    }

    .btn{
        width:220px;
    }
}
