        &lt;button class=&quot;small-btn&quot; id=&quot;restartBtn&quot;&gt;
            🔄 Заново
        &lt;/button&gt;

        &lt;button class=&quot;small-btn&quot; id=&quot;menuBtn&quot;&gt;
            🏠 Меню
        &lt;/button&gt;

