&lt;script&gt;
/* ФОН */
const bg = document.getElementById(&quot;bg&quot;);

for(let i=0;i&lt;35;i++){

    const bubble = document.createElement(&quot;span&quot;);

    const size = Math.random()*40+10;

    bubble.style.width = size+&quot;px&quot;;
    bubble.style.height = size+&quot;px&quot;;
    bubble.style.left = Math.random()*100+&quot;%&quot;;
    bubble.style.animationDuration =
        Math.random()*15+10+&quot;s&quot;;

    bg.appendChild(bubble);
}

/* ЭКРАНЫ */
const menuScreen = document.getElementById(&quot;menuScreen&quot;);
const gameScreen = document.getElementById(&quot;gameScreen&quot;);

const playBtn = document.getElementById(&quot;playBtn&quot;);
const exitBtn = document.getElementById(&quot;exitBtn&quot;);

const chooseX = document.getElementById(&quot;chooseX&quot;);
const chooseO = document.getElementById(&quot;chooseO&quot;);

const statusText = document.getElementById(&quot;status&quot;);
const board = document.getElementById(&quot;board&quot;);

let player = &quot;X&quot;;
let bot = &quot;O&quot;;

chooseX.onclick = () =&gt; {

    player = &quot;X&quot;;
    bot = &quot;O&quot;;

    chooseX.classList.add(&quot;selected&quot;);
    chooseO.classList.remove(&quot;selected&quot;);
};

chooseO.onclick = () =&gt; {

    player = &quot;O&quot;;
    bot = &quot;X&quot;;

    chooseO.classList.add(&quot;selected&quot;);
    chooseX.classList.remove(&quot;selected&quot;);
};

exitBtn.onclick = () =&gt; {
    alert(&quot;Спасибо за игру 😎&quot;);
};

/* ИГРА */
let currentPlayer = &quot;X&quot;;
let gameActive = true;

let cells = [&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;];

const winPatterns = [
    [0,1,2],
    [3,4,5],
    [6,7,8],
    [0,3,6],
    [1,4,7],
    [2,5,8],
    [0,4,8],
    [2,4,6]
];

playBtn.onclick = () =&gt; {

    menuScreen.classList.add(&quot;hidden&quot;);
    gameScreen.classList.remove(&quot;hidden&quot;);

    restartGame();

    if(bot === &quot;X&quot;){
        setTimeout(botMove,500);
    }
};

function createBoard(){

    board.innerHTML = &quot;&quot;;

    cells.forEach((cell,index)=&gt;{

        const cellDiv = document.createElement(&quot;div&quot;);

        cellDiv.classList.add(&quot;cell&quot;);

        if(cell === &quot;X&quot;) cellDiv.classList.add(&quot;x&quot;);
        if(cell === &quot;O&quot;) cellDiv.classList.add(&quot;o&quot;);

        cellDiv.textContent = cell;

        cellDiv.addEventListener(&quot;click&quot;,()=&gt;{
            playerMove(index);
        });

        board.appendChild(cellDiv);
    });
}

function playerMove(index){

    if(!gameActive) return;

    if(currentPlayer !== player) return;

    if(cells[index] !== &quot;&quot;) return;

    cells[index] = player;

    createBoard();

    if(checkWinner()) return;

    currentPlayer = bot;

    statusText.textContent = `Ход: ${bot}`;

    setTimeout(botMove,500);
}

function botMove(){

    if(!gameActive) return;

    let emptyIndexes = [];

    for(let i=0;i&lt;cells.length;i++){

        if(cells[i] === &quot;&quot;){
            emptyIndexes.push(i);
        }
    }

    if(emptyIndexes.length === 0) return;

    const randomIndex =
        emptyIndexes[
            Math.floor(Math.random()*emptyIndexes.length)
        ];

    cells[randomIndex] = bot;

    createBoard();

    if(checkWinner()) return;

    currentPlayer = player;

    statusText.textContent = `Ход: ${player}`;
}

function checkWinner(){

    for(const pattern of winPatterns){

        const [a,b,c] = pattern;

        if(
            cells[a] &amp;&amp;
            cells[a] === cells[b] &amp;&amp;
            cells[a] === cells[c]
        ){

            gameActive = false;

            statusText.textContent =
                `Победил ${cells[a]} 🎉`;

            return true;
        }
    }

    if(!cells.includes(&quot;&quot;)){

        gameActive = false;

        statusText.textContent = &quot;Ничья 🤝&quot;;

        return true;
    }

    return false;
}

function restartGame(){

    currentPlayer = &quot;X&quot;;
    gameActive = true;

    cells = [&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;,&quot;&quot;];

    statusText.textContent = &quot;Ход: X&quot;;

    createBoard();

    if(bot === &quot;X&quot;){
        setTimeout(botMove,500);
    }
}

document.getElementById(&quot;restartBtn&quot;).onclick =
restartGame;

document.getElementById(&quot;menuBtn&quot;).onclick = () =&gt; {

    gameScreen.classList.add(&quot;hidden&quot;);
    menuScreen.classList.remove(&quot;hidden&quot;);

    restartGame();
};

createBoard();
&lt;/script&gt;

